#BFF_SYSTEM_PROMPT="you are SNAPPER a robot dog looking for conversation with your human. you do not say woof, whir, tail wag. do not use headers, bullets, or markdown formatting. do not say processing. speak plainly."

# all are good
# BFF_OLLAMA_MODEL=gemma4:e4b
BFF_OLLAMA_MODEL=gemma4:e2b
# BFF_OLLAMA_MODEL=gemma4:e2b-mlx

# needs a longer num_predict cutoff
# BFF_OLLAMA_MODEL=deepseek-r1:1.5b

# how much do we share in the log
# BFF_WORKER_VERBOSE=1

BFF_HISTORY_TRUNCATION_LIMIT=30
#11

# Ollama generation options
BFF_OLLAMA_TEMPERATURE=0.7
BFF_OLLAMA_TOP_P=0.9
BFF_OLLAMA_TOP_K=40
# BFF_OLLAMA_NUM_PREDICT=100
BFF_OLLAMA_NUM_PREDICT=200
BFF_OLLAMA_NUM_CTX=2048
BFF_OLLAMA_THINK=false

# Speech recognition parameters
BFF_WHISPER_MODEL=tiny.en
BFF_SAMPLE_RATE=16000
# BFF_INPUT_DEVICE_KEYWORD="OpenRun Pro 2 by Shokz"
# BFF_INPUT_DEVICE_KEYWORD="MacBook Air Microphone"
BFF_INPUT_DEVICE_KEYWORD="Wireless Mic Rx, DJI"
BFF_ACTIVATION_THRESHOLD=0.03
# BFF_COUPLING_FACTOR=0.5
BFF_SILENCE_THRESHOLD=0.015
BFF_SILENCE_DURATION=0.8
BFF_MIN_PHRASE_SECONDS=0.5
BFF_BLOCK_DURATION=0.2
BFF_LOG_ROOT=~/bff/logs

BFF_REQUIRE_WAKEWORD=true
BFF_WAKE_PHRASES="ok snapper, okay snapper, hey snapper, snapper, snap or, snupper, snabber, snabbor, snapbert"

# Voice synthesis parameters
# BFF_PIPER_VOICE=/home/cohab/code/bff-code/speech/piper/en_GB-alan-medium.onnx
# BFF_PLAYBACK_SPEED=2.0
# BFF_PIPER_VOICE=/home/cohab/code/bff-code/speech/piper/en_GB-aru-medium.onnx
BFF_PIPER_VOICE=/home/cohab/code/bff-code/speech/piper/en_GB-aru-medium.onnx
BFF_PLAYBACK_SPEED=1.25
BFF_PLAYBACK_TAIL_SILENCE=0.25 

BFF_INTERRUPTABLE=false
BFF_FLUSH_ON_INTERRUPT=true

# Speech gating
BFF_BARGE_IN_BLOCKS=6        # 1.2s confirmation window — lets the duck actually take effect
BFF_DUCK_LEVEL=0.05          # near-mute during the probe
BFF_BARGE_IN_MIN_RMS=0.05    # NEW: candidate blocks must also be loud at the mic
BFF_BARGE_IN_THRESHOLD=0.8   # optional: slightly stricter
BFF_VAD_THRESHOLD=0.85


# BFF_PULSE_SINKS="alsa_output.usb-Generic_USB2.0_Device_20170726905959-00.analog-stereo,bluez_sink.A0_0C_E2_12_BC_82.handsfree_head_unit"
# BFF_PULSE_COMBINED_SINK_NAME="bff_combined"
BFF_PULSE_SOURCE_VOLUME=60%

# Unitree Go2 Connection & Capture Configuration
# Direct ethernet to the robot's SOC rather than over wifi:
# 0.21ms vs 3.5ms RTT, ~100x less jitter, and it keeps working
# out of range of the house AP. Wifi IP was 192.168.4.30
UNITREE_ROBOT_IP=192.168.123.161
#UNITREE_ROBOT_IP=192.168.123.1
UNITREE_AES_KEY=

# Dashboard / Capture stream overrides (true/false)
BFF_CAPTURE_VIDEO=true
BFF_CAPTURE_AUDIO=true
BFF_CAPTURE_LOWSTATE=true
BFF_CAPTURE_LIDAR=true
BFF_VIDEO_FPS=30
BFF_DASHBOARD_PORT=8080

# VLM Background Worker & Query Configuration
BFF_VLM_MODEL=gemma4:e2b

# Minimum gap between capture starts; 0.0 = continuous, paced only by the VLM's own latency
BFF_VLM_INTERVAL=10.0

# YOLO Object Detection Configuration
BFF_YOLO_MODEL=yolo11n.pt
# BFF_YOLO_MODEL=yolov8s-oiv7.pt

# Behavioral State Machine Configuration
BFF_IDLE_TIMEOUT=120
LAST_HEADSET_MAC=A0:0C:E2:12:BC:82
LAST_HEADSET_NAME="OpenRun Pro 2 by Shokz"
BFF_VLM_NUM_PREDICT=40
